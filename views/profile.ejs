<%- include('templates/header', { pageTitle: 'Profile', css: ['profile.css'] })  %>
  <div class="d-flex p-2 heading-styling">
    <h2 class="heading-element">
      Hello User!
    </h2>
    <div class="earned-points">
      <img src="/images/plant_points.svg" alt="plant-points-logo" class="img-earned-points">
      <p class="text-earned-points"> Earned Points</p>
      <p class="text-earned-points"> 25 </p>
      <img src="/images/pp.svg" alt="plant-points" class="plant-points-logo">
    </div>
  </div>

  <div class="container ">
    <form action="/profilemodal" method="POST" class="container-custom-flex ">

      <% for(let reward of rewards) { %>
        <label for="<%= reward.id %>-option">
          <input type="radio" id="<%= reward.id %>-option" value="<%= reward.value %>" name="reward">
          <div class="alert alert-danger bg-light card-custom-flex">
            <img src="/images/<%= reward.pointsImg %>.svg" alt="" class="plant-points">
            <img src="/images/Arrow.svg" alt="" class="plant-points">
            <img src="/images/<%= reward.rewardImg %>.svg" alt="" class="plant-points">
          </div>
        </label>

        <% } %>

          <button type="submit" class="btn btn-success redeem-btn">Redeem</button>

    </form>
  </div>
<%- include('templates/footer') %>