<%- include('templates/header', { pageTitle: 'Information', css: ['info.css'] })  %>

  <nav class="navbar position-relative">
    <div class="container-fluid justify-content-center position-relative">

      <div class="d-flex align-items-center gap-2 search-form">
        <input
          class="form-control search-input"
          type="search"
          placeholder="Eg.Blueberry"
          aria-label="Search"
        />
        <button class="filter-button btn d-flex align-items-center justify-content-center" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#6B4F32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="6" x2="20" y2="6"/>
            <line x1="8" y1="12" x2="16" y2="12"/>
            <line x1="11" y1="18" x2="13" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Filter Panel -->
      <div id="filter-panel" class="filter-panel d-none">
        <div class="d-flex flex-wrap gap-2 mb-2">
          <button id="pill-favourites" class="filter-opt-btn d-none">Favourites</button>
          <button id="pill-edible" class="filter-opt-btn">Edible</button>
          <button id="pill-non-edible" class="filter-opt-btn">Non Edible</button>
        </div>
        <button id="clear-filters" class="clear-filter-link">Clear filter</button>
      </div>

    </div>
  </nav>

  <div class="container d-flex justify-content-center flex-wrap gap-4 mt-5 info-card-container">
    <% plants.forEach(function(plant) { %>
      <div
        class="card plant-card"
        style="width: 18rem"
        data-edible="<%= plant.isEdible %>"
        data-favourite="<%= plant.favourite %>"
        data-name="<%= plant.name.toLowerCase() %>"
        data-description="<%= (plant.description || '').toLowerCase() %>"
      >
        <img src="<%= plant.image %>" class="card-img-top" alt="<%= plant.name %>" />
        <div class="card-body">
          <div class="card-title-row">
            <h5 class="card-title mb-0"><%= plant.name %></h5>
            <button
              class="save-btn <%= plant.favourite ? 'saved' : '' %>"
              data-id="<%= plant._id %>"
              data-favourite="<%= plant.favourite %>"
              aria-label="Save plant"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" style="display:block;">
                <path d="M5 3h14a1 1 0 0 1 1 1v17l-8-4-8 4V4a1 1 0 0 1 1-1z" class="bookmark-icon"/>
              </svg>
            </button>
          </div>
          <p class="card-text mt-2"><%= plant.description %></p>
        </div>
        <ul class="list-group list-group-flush">
          <li class="list-group-item"><b>Edible:</b> <%= plant.isEdible ? "True" : "False" %></li>
          <li class="list-group-item"><b>Location:</b> <%= plant.location %></li>
          <li class="list-group-item"><b>Habitat:</b> <%= plant.habitat %></li>
        </ul>
      </div>
    <% }) %>
  </div>

<%- include('templates/footer', { js: ['filter.js'] }) %>