<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Plant Safety Quiz</title>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Google Material Icons -->
    <link
      href="https://fonts.googleapis.com/icon?family=Material+Icons"
      rel="stylesheet"
    />

    <!-- CSS -->
    <link rel="stylesheet" href="/css/quiz.css" />
  </head>

  <body>
    <div
      class="page-background d-flex justify-content-center align-items-center"
    >
      <div>
        <div class="phone-card d-flex flex-column">
          <div
            class="content-area d-flex flex-column justify-content-center align-items-center text-center"
          >
            <h1 class="title-text">
              Test your plant safety<br />
              knowledge
            </h1>

            <a href="/game" class="btn start-btn">Start Quiz</a>

            <!-- Herf can be changed - can be -->
            <button type="button" id="tutorial-btn" class="btn start-btn">
              Start Tutorial
            </button>
          </div>

          <%- include('templates/footer') %>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/tutorial.js"></script>
  </body>
</html>
