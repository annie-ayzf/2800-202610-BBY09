<%- include('templates/header', { pageTitle: 'Quiz', css: ['gameresult.css'] })  %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<div class="min-vh-100 d-flex flex-column px-3 py-4">

    <!-- WORK BANNER -->
    <div class="alert alert-success text-center fw-bold fs-5 mb-3 mx-n3 rounded-3" role="alert">
        <h1>Nice work, Name!</h1>
        <br>
    </div>

    <div class="card text-center">

        <!-- Progress bar shows correct answers in green and missed answers in red -->
        <!-- Bootstrap animated striped bar — two segments share one container -->
        <div class="result-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100">
            <!-- Green segment — width driven by --greenWidth CSS variable in gameresult.css -->
            <div
              class="progress-bar progress-bar-striped progress-bar-animated result-green"
              style="--greenWidth: <%= (score / total) * 100 %>%"
              aria-valuenow="<%= (score / total) * 100 %>"
            ></div>
            <!-- Red segment — width driven by --redWidth CSS variable in gameresult.css -->
            <div
              class="progress-bar progress-bar-striped progress-bar-animated result-red"
              style="--redWidth: <%= ((total - score) / total) * 100 %>%"
              aria-valuenow="<%= ((total - score) / total) * 100 %>"
            ></div>
        </div>

        <!-- TOTAL POINT BOX -->
        <div class="resultCard-body">
            <h5 class="card-title">TOTAL POINTS</h5>
            <p class="card-text"><%= typeof totalPoints !== 'undefined' ? totalPoints : 0 %></p>
        </div>

        <div class="card-footer text-body-secondary">
            <div class="d-flex gap-2 justify-content-center">
                <div class="card border-success mb-3 flex-fill">
                    <div class="card-body text-success">
                        <h5 class="card-title">CORRECT</h5>
                        <p class="card-text"><%= score %></p>
                    </div>
                </div>
                <div class="card border-danger mb-3 flex-fill">
                    <div class="card-body text-danger">
                        <h5 class="card-title">MISSED</h5>
                        <p class="card-text"><%= total - score %></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-2">
        <div class="alert alert-warning d-inline-flex align-items-center gap-2 px-3 py-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>Be careful of your surroundings!</span>
        </div>
    </div>

    <div class="d-flex gap-2 pb-2 mt-3 mx-auto" style="width: 90%;">
        <a href="/restartquiz" class="btn btn-lg fw-semibold btn-continue rounded-3 flex-fill">Play Again</a>
        <a href="/quiz" class="btn btn-lg fw-semibold btn-continue rounded-3 flex-fill">Home</a>
    </div>

</div>
<%- include('templates/footer') %>
