<%- include('templates/header', { pageTitle: 'Quiz', css: ['gameincorrect.css'] })  %>
<div class="min-vh-100 d-flex flex-column px-3 py-4">

  <!-- Progress bar -->
<div class="d-flex align-items-center justify-content-between mb-3">

  <!-- Red progress bar fills as questions go by -->
  <div class="progress flex-grow-1 me-2" role="progressbar" 
       aria-label="Lives" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"
       style="height: 12px;">

    <div class="progress-bar progress-bar-striped bg-danger"
      style="width: <%= (questionNumber / 5) * 100 %>%">
    </div>
  </div>

  <!-- Points badge shows total user coins -->
  <span class="badge rounded-circle d-flex align-items-center justify-content-center fw-bold"
        style="width: 40px; height: 40px; font-size: 1rem; background-color: #e8bb6c; color: #fffefb;">
    <%= totalPoints %>
  </span>

</div>

  <!-- NOT EDIBLE banner -->
  <div class="alert alert-danger text-center fw-bold fs-5 mb-3 mx-n3 rounded-3" role="alert">
    ☠️ NOT EDIBLE!!
  </div>

  <!-- Plant card -->
  <div class="card border-0 shadow-sm mb-3 overflow-hidden">
    <div class="row g-0">

      <!-- Images -->
     <div class="col-4 d-flex align-items-center justify-content-center" style="min-height: 120px; background-color: #606C38;">
        <% if (plant && plant.image) { %>
          <img
            src="<%= plant.image %>"
            alt=""
            class="img-fluid w-100"
            style="height: 120px; object-fit: cover;"
            onerror="this.parentElement.innerHTML='<span style=\'font-size:2.5rem;\'>🌿</span>';">
          <% } else { %>
         <span style="font-size: 2.5rem;">🌿</span>
        <% } %>
      </div>

      <div class="col-8">
        <div class="card-bodyIncorrectPlants py-2 px-3">
          <h6 class="card-title fw-bold mb-1 plant-name"><%= plant.name %></h6>
          <% if (plant.scientificName) { %>
            <p class="fst-italic text-muted mb-1" style="font-size:0.77rem;"><%= plant.scientificName %></p>
          <% } %>
          <% if (plant.habitat) { %>
            <p class="text-muted mb-1" style="font-size:0.77rem;">Habitat: <%= plant.habitat %></p>
          <% } %>
          <% if (plant.location) { %>
            <p class="text-muted mb-0" style="font-size:0.77rem;">Location: <%= plant.location %></p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Description card -->
  <div class="cardDescription border-0 shadow-sm mb-4 flex-grow-1" 
       style="min-height: 0;">
    <div class="card-body d-flex flex-column h-100">
      <p class="fw-semibold mb-2 desc-label">DESCRIPTION</p>
      <div class="overflow-y-auto flex-grow-1" 
           style="max-height: 35vh;">
        <p class="mb-0" style="font-size:0.88rem; line-height:1.65;">
          <%= plant.description %>
        </p>
      </div>
    </div>
  </div>

  <!-- Spacer to push button to bottom -->
  <div class="flex-grow-1"></div>

  <!-- Continue button - full width at bottom -->
  <div class="continuebtn d-grid px-1 pb-2 mt-auto">
    <a href="/game" class="btn btn-lg fw-semibold btn-continue rounded-3">CONTINUE</a>
  </div>
  
  </div>
</div>
<%- include('templates/footer', { js: ['gameincorrect.js'] }) %>