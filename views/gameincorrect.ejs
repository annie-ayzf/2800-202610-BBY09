<!-- gameincorrect.ejs — Wrong answer feedback screen
  Rendered by GET /gameincorrect after the player answers incorrectly.
  Receives: plant (object), questionNumber (1-5), totalPoints (number)

  Shows the plant the player got wrong with its details and description,
  then lets them continue to the next question via GET /game.
-->

<%- include('templates/header', { pageTitle: 'Quiz', css: ['gameincorrect.css'] }) %>

<div class="min-vh-100 d-flex flex-column px-3 py-4">

  <!-- Progress bar + points badge -->
  <div class="d-flex align-items-center justify-content-between mb-3">

    <!-- Animated striped bar — same --progress pattern as game.ejs.
    questionNumber - 1 reflects questions already answered. -->
    <% const progressPct = ((questionNumber - 1) / 5) * 100; %>
    <div class="progress flex-grow-1 me-2" role="progressbar"
      aria-label="Quiz progress" aria-valuenow="<%- progressPct %>"
      aria-valuemin="0" aria-valuemax="100" style="height: 12px;">
      <div class="progress-bar progress-bar-striped progress-bar-animated progress-fill"
       style="--progress: <%- progressPct %>%;">
      </div>
    </div>

    <!-- Points badge — falls back to 0 if totalPoints is not passed -->
    <span class="badge rounded-circle d-flex align-items-center justify-content-center fw-bold"
          style="width: 40px; height: 40px; font-size: 1rem; background-color: #e8bb6c; color: #fffefb;">
      <%= typeof totalPoints !== 'undefined' ? totalPoints : 0 %>
    </span>
  </div>

  <!-- Warning banner shown when the player guesses an inedible plant as edible -->
  <div class="alert alert-danger text-center fw-bold fs-5 mb-3 mx-n3 rounded-3" role="alert">
    ☠️ NOT EDIBLE!!
  </div>

  <!-- Plant card: image left, details right -->
  <div class="card border-0 shadow-sm mb-3 overflow-hidden">
    <div class="row g-0">

      <!-- Plant image with emoji fallback if image is missing or broken -->
      <div class="col-4 d-flex align-items-center justify-content-center"
        style="min-height: 120px; background-color: #606C38;">
        <% if (plant && plant.image) { %>
          <img
            src="<%= plant.image %>"
            alt="<%= plant.name %>"
            class="img-fluid w-100"
            style="height: 120px; object-fit: cover;"
            onerror="this.parentElement.innerHTML='<span style=\'font-size:2.5rem;\'>🌿</span>';"
          />
        <% } else { %>
          <span style="font-size: 2.5rem;">🌿</span>
        <% } %>
      </div>

      <!-- Plant metadata — each field only renders if the value exists.
       Refactored: three identical if/p blocks collapsed into a metaFields loop. -->
      <div class="col-8">
        <div class="card-bodyIncorrectPlants py-2 px-3">
          <h6 class="card-title fw-bold mb-1 plant-name"><%= plant.name %></h6>

          <% if (plant.scientificName) { %>
            <p class="fst-italic text-muted mb-1" style="font-size: 0.77rem;"><%= plant.scientificName %></p>
          <% } %>
          <% if (plant.habitat) { %>
            <p class="text-muted mb-1" style="font-size: 0.77rem;">Habitat: <%= plant.habitat %></p>
          <% } %>
          <% if (plant.location) { %>
            <p class="text-muted mb-0" style="font-size: 0.77rem;">Location: <%= plant.location %></p>
          <% } %>
        </div>
      </div>

    </div>
  </div>

  <!-- Scrollable description card -->
  <div class="cardDescription border-0 shadow-sm mb-4 flex-grow-1" style="min-height: 0;">
    <div class="card-body d-flex flex-column h-100">
      <p class="fw-semibold mb-2 desc-label">DESCRIPTION</p>
      <!-- max-height cap keeps the card from overflowing on short screens -->
      <div class="overflow-y-auto flex-grow-1" style="max-height: 35vh;">
        <p class="mb-0" style="font-size: 0.88rem; line-height: 1.65;">
          <%= plant.description %>
        </p>
      </div>
    </div>
  </div>

  <!-- Spacer pushes the continue button to the bottom of the screen -->
  <div class="flex-grow-1"></div>

  <!-- Continue button — returns to /game for the next question -->
  <div class="continuebtn d-grid px-1 pb-2 mt-auto">
    <a href="/game" class="btn btn-lg fw-semibold btn-continue rounded-3">CONTINUE</a>
  </div>

</div>

<%- include('templates/footer') %>
