<%- include('./templates/header') %>

<!-- contains the page-->
<div class="container">

   <!-- Progress bar for incorrect guess - width will be changed based on level of question -->
  <div class="progress" role="progressbar" aria-label="Animated striped example" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">
    <div class="progress-bar progress-bar-striped progress-bar-animated bg-danger" style="width: 75%"></div>
  </div>

  <!-- Incorrect guess message-->
  <div class="alert alert-danger" role="alert">
  A simple danger alert with no link. Give it a click if you like.
  </div>

  <!-- Card-plant  for incorrect guess -->
  <div class="card mb-3" style="max-width: 540px;">
    <div class="row g-0">
      <div class="col-md-4">
        <img src="..." class="img-fluid rounded-start" alt="🌱" width="36px" height="36px" style="display: block; margin: 0 auto;">
      </div>
    <div class="col-md-8">
      <div class="card-body">
        <h5 class="card-title">Plant name title</h5>
        <p class="card-text">This is a wider card with supporting text below as a natural lead-in to additional content. This content is a little bit longer.</p>
      </div>
    </div>
    </div>
  </div>

  <!-- Description -->
  <div class="card border-warning mb-3" style="max-width: 18rem;">
    <div class="card-header">Header</div>
      <div class="card-body">
        <h5 class="card-title">Warning card title</h5>
        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card’s content.</p>
      </div>
  </div>

  <!-- Button to go to next question -->
  <div class="d-grid gap-2">
    <button class="btn btn-success" type="button">Continue</button>
  </div>
  
</div>

</body>
</html>