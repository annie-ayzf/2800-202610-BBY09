<%- include('./templates/header') %>

<link rel="stylesheet" href="../src/css/gameincorrect.css">

<!-- contains the page-->
<div class="container">

   <!-- Progress bar for incorrect guess - width will be changed based on level of question -->
<div class="progress" role="progressbar" aria-label="Quiz progress" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">
  <div class="progress-bar progress-bar-striped progress-bar-animated bg-danger" style="width: ('<%= typeof currentQuestion !== 'undefined' ? (currentQuestion / totalQuestions) * 100 : 60 %>%>');"></div>
</div>

  <!-- Incorrect guess message-->
  <div class="alert alert-danger" role="alert">
  A simple danger alert with no link. Give it a click if you like.
  </div>

  <!-- Card-plant  for incorrect guess -->
  <div class="plant-card">
    <% if (plant && plant.image) { %>
      <img src="<%= plant.image %>" alt="<%= plant.name %>">
    <% } else { %>
      <div class="plant-card-placeholder">🌿</div>
    <% } %>
    <div class="plant-card-info">
      <h5><%= plant ? plant.name : 'Plant Name' %></h5>
      <% if (plant && plant.scientific_name) { %>
        <div class="scientific"><%= plant.scientific_name %></div>
      <% } %>
      <div class="location">📍 <%= plant ? plant.location : 'Location' %></div>
    </div>
  </div>

  <!-- Description -->
  <div class="description-card">
    <div class="desc-label">⚠ Description</div>
    <p><%= plant ? plant.description : 'Plant description will appear here.' %></p>
  </div>
  </div>

  <!-- Button to go to next question -->
  <div class="d-grid gap-2">
    <button class="btn btn-success" type="button">
  <a href="/game" class="btn-continue">CONTINUE</a>
</button>
  </div>

</div>

</body>
</html>
